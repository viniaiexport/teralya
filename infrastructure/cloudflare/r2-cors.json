{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://teralya.eu",
          "https://www.teralya.eu"
        ],
        "methods": [
          "GET",
          "HEAD",
          "PUT"
        ],
        "headers": [
          "Content-Type",
          "If-None-Match",
          "x-amz-checksum-sha256"
        ]
      },
      "exposeHeaders": [
        "ETag"
      ],
      "maxAgeSeconds": 3600
    }
  ]
}
