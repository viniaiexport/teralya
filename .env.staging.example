NODE_ENV=production
PORT=3001
FRONTEND_PORT=3000
BACKEND_PORT=3001
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://teralya:replace-with-a-long-random-password@postgres:5432/teralya
REDIS_URL=redis://redis:6379
PUBLIC_BASE_URL=http://localhost:3001
TERALYA_API_URL=http://backend:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

OBJECT_STORAGE_REGION=eu-west-1
OBJECT_STORAGE_BUCKET=replace-with-staging-bucket
OBJECT_STORAGE_ENDPOINT=https://replace-with-object-storage-endpoint.example
OBJECT_STORAGE_FORCE_PATH_STYLE=false
OBJECT_STORAGE_ACCESS_KEY_ID=replace-with-access-key
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-with-secret-key
OBJECT_STORAGE_CDN_BASE_URL=https://replace-with-staging-cdn.example
IMAGE_CONFIRMATION_HMAC_SECRET=replace-with-at-least-32-random-characters

STRIPE_WEBHOOK_SECRET=replace-with-staging-webhook-secret
STRIPE_SECRET_KEY=replace-with-stripe-test-secret
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/checkout/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/checkout/cancel
STRIPE_CHECKOUT_TTL_SECONDS=1800

# Valores provisionales exclusivos de staging; producción queda bloqueada hasta validación legal.
MINIMUM_PURCHASE_AGE=18
ALCOHOL_TERMS_VERSION=staging-not-for-production

# Valores provisionales exclusivos de staging; producción requiere aprobación de Seguridad.
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
PASSWORD_RECOVERY_TOKEN_TTL_SECONDS=3600
PASSWORD_RECOVERY_RATE_LIMIT_MAX_ATTEMPTS=3
PASSWORD_RECOVERY_RATE_LIMIT_WINDOW_SECONDS=900
PASSWORD_RECOVERY_URL=http://localhost:3000/restablecer-password
PASSWORD_RECOVERY_FROM_EMAIL=no-reply@staging.teralya.eu
SMTP_HOST=replace-with-smtp-host
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password

