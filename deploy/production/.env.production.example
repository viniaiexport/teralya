NODE_ENV=production
PORT=3001

SITE_DOMAIN=teralya.eu
API_DOMAIN=api.teralya.eu
ACME_EMAIL=infra@teralya.eu
PUBLIC_BASE_URL=https://api.teralya.eu
TERALYA_API_URL=http://backend:3001
NEXT_PUBLIC_SITE_URL=https://teralya.eu

FRONTEND_IMAGE=ghcr.io/viniaiexport/teralya-frontend:replace-with-sha
BACKEND_IMAGE=ghcr.io/viniaiexport/teralya-backend:replace-with-sha

POSTGRES_PASSWORD=replace-with-at-least-32-random-characters
DATABASE_URL=postgresql://teralya:replace-with-url-encoded-password@postgres:5432/teralya
REDIS_PASSWORD=replace-with-at-least-32-random-characters
REDIS_URL=redis://:replace-with-url-encoded-password@redis:6379

OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=teralya-production-media
OBJECT_STORAGE_ENDPOINT=https://replace-with-account-id.eu.r2.cloudflarestorage.com
OBJECT_STORAGE_FORCE_PATH_STYLE=false
OBJECT_STORAGE_ACCESS_KEY_ID=replace-with-bucket-scoped-r2-access-key
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-with-bucket-scoped-r2-secret-key
OBJECT_STORAGE_CDN_BASE_URL=https://media.teralya.eu
IMAGE_CONFIRMATION_HMAC_SECRET=replace-with-at-least-32-random-characters

STRIPE_WEBHOOK_SECRET=replace-with-live-webhook-secret
STRIPE_SECRET_KEY=replace-with-live-secret-key
STRIPE_CHECKOUT_SUCCESS_URL=https://teralya.eu/checkout/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=https://teralya.eu/checkout/cancel
STRIPE_CHECKOUT_TTL_SECONDS=1800

MINIMUM_PURCHASE_AGE=18
ALCOHOL_TERMS_VERSION=LEGAL-06-v1.0

LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
PASSWORD_RECOVERY_TOKEN_TTL_SECONDS=3600
PASSWORD_RECOVERY_RATE_LIMIT_MAX_ATTEMPTS=3
PASSWORD_RECOVERY_RATE_LIMIT_WINDOW_SECONDS=900
PASSWORD_RECOVERY_URL=https://teralya.eu/restablecer-password
PASSWORD_RECOVERY_FROM_EMAIL=no-reply@teralya.eu
SMTP_HOST=replace-with-smtp-host
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password

R2_BACKUP_BUCKET=teralya-production-backups
R2_BACKUP_ENDPOINT=https://replace-with-account-id.eu.r2.cloudflarestorage.com
R2_BACKUP_ACCESS_KEY_ID=replace-with-backup-bucket-access-key
R2_BACKUP_SECRET_ACCESS_KEY=replace-with-backup-bucket-secret-key
