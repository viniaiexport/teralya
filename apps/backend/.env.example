NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://teralya:teralya_local@localhost:5432/teralya
REDIS_URL=redis://localhost:6379
PUBLIC_BASE_URL=http://localhost:3001
STRIPE_WEBHOOK_SECRET=whsec_local_placeholder
# Valor local de desarrollo; producción debe fijarlo tras validación legal.
MINIMUM_PURCHASE_AGE=18
# Sustituir en cada entorno por la versión publicada y vigente.
ALCOHOL_TERMS_VERSION=local-placeholder
# Valores locales; producción debe fijarlos tras revisión de seguridad.
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
PASSWORD_RECOVERY_TOKEN_TTL_SECONDS=3600
PASSWORD_RECOVERY_RATE_LIMIT_MAX_ATTEMPTS=3
PASSWORD_RECOVERY_RATE_LIMIT_WINDOW_SECONDS=900
# Ruta pública del frontend que consume el token de API-004.
PASSWORD_RECOVERY_URL=http://localhost:3000/restablecer-password
PASSWORD_RECOVERY_FROM_EMAIL=no-reply@teralya.local
# Transporte SMTP estándar: producción puede elegir proveedor sin cambiar código.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=local
SMTP_PASSWORD=local
