{
  "name": "teralya",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "backend:build": "npm run build --workspace @teralya/backend",
    "backend:lint": "npm run lint --workspace @teralya/backend",
    "backend:test": "npm run test --workspace @teralya/backend",
    "backend:check": "npm run lint --workspace @teralya/backend && npm run test --workspace @teralya/backend && npm run build --workspace @teralya/backend",
    "frontend:dev": "npm run dev --workspace @teralya/frontend",
    "frontend:build": "npm run build --workspace @teralya/frontend",
    "frontend:lint": "npm run lint --workspace @teralya/frontend",
    "frontend:test": "npm run test --workspace @teralya/frontend",
    "frontend:e2e": "npm run e2e --workspace @teralya/frontend",
    "frontend:audit": "npm audit --omit=dev --audit-level=high",
    "frontend:check": "npm run check --workspace @teralya/frontend"
  }
}
